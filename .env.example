# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=clinical_db

# JWT — generá una clave larga y aleatoria para producción
# Ejemplo: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Entorno: development | production
NODE_ENV=development
